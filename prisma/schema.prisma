generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  timezone     String   @default("America/Toronto")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships   GroupMember[]
  assignedTasks TaskAssignment[]
  actions       TaskAction[]
  messages      ConversationMessage[]
  ownedGroups   TaskGroup[]           @relation("GroupOwner")
  devices       Device[]
  createdTasks  Task[]                @relation("TaskCreator")
}

model TaskGroup {
  id          String   @id @default(cuid())
  name        String
  description String?
  inviteCode  String   @unique
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner    User                  @relation("GroupOwner", fields: [ownerId], references: [id])
  members  GroupMember[]
  tasks    Task[]
  messages ConversationMessage[]
  rules    GroupRule[]
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  role      String   @default("MEMBER") // OWNER | COORDINATOR | MEMBER | DEPENDENT | GUEST
  joinedAt  DateTime @default(now())
  available Boolean  @default(true)
  skills    String   @default("[]")

  group TaskGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model Task {
  id               String    @id @default(cuid())
  groupId          String
  creatorId        String
  title            String
  description      String?
  status           String    @default("UPCOMING")
  priority         String    @default("NORMAL")
  dueAt            DateTime?
  remindAt         DateTime?
  deadlineHard     Boolean   @default(true)
  recurrenceRule   String?
  verificationType String    @default("CHECKBOX")
  escalationStage  Int       @default(0)
  primaryUserId    String?
  backupUserId     String?
  locationHint     String?
  notes            String?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  group       TaskGroup        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  creator     User             @relation("TaskCreator", fields: [creatorId], references: [id])
  assignments TaskAssignment[]
  actions     TaskAction[]
}

model TaskAssignment {
  id         String   @id @default(cuid())
  taskId     String
  userId     String
  role       String   @default("PRIMARY") // PRIMARY | BACKUP | HELPER | WATCHER
  commitment String   @default("PENDING") // PENDING | ACCEPTED | DECLINED | ...
  reason     String?
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
}

model TaskAction {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  type      String
  payload   String?
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ConversationMessage {
  id        String   @id @default(cuid())
  groupId   String
  userId    String?
  role      String
  content   String
  createdAt DateTime @default(now())

  group TaskGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User?     @relation(fields: [userId], references: [id])
}

model GroupRule {
  id        String   @id @default(cuid())
  groupId   String
  name      String
  ruleText  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  group TaskGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model Device {
  id        String   @id @default(cuid())
  userId    String
  name      String
  kind      String
  online    Boolean  @default(false)
  canWorker Boolean  @default(false)
  lastSeen  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
